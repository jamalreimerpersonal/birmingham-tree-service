---
import { PHONE_NUMBER, SITE_NAME } from '../utils/constants';

interface NavItem {
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/tree-removal' },
  { label: 'Locations', href: '/locations' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <div class="w-10 h-10 bg-green-600 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 1a9 9 0 100 18 9 9 0 000-18zm0 16a7 7 0 110-14 7 7 0 010 14z" />
          </svg>
        </div>
        <span class="hidden sm:inline font-bold text-lg text-gray-900">{SITE_NAME}</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex gap-8">
        {navItems.map(item => (
          <a 
            href={item.href}
            class="text-gray-700 hover:text-green-600 transition font-medium text-sm"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <div class="flex items-center gap-4">
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="hidden sm:inline text-green-600 font-bold hover:text-green-700"
        >
          {PHONE_NUMBER}
        </a>
        
          href={`tel:${PHONE_NUMBER}`}
          class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition font-semibold text-sm"
        >
          Call Now
        </a>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div class="md:hidden text-center pb-2">
      <p class="text-xs text-green-600 font-bold">
        <a href={`tel:${PHONE_NUMBER}`}>{PHONE_NUMBER}</a>
      </p>
    </div>
  </div>
</header>
