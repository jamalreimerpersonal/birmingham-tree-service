---
interface Props {
  name: string;
  description: string;
  neighborhoods?: string[];
  href: string;
}

const { name, description, neighborhoods, href } = Astro.props;
---

<a href={href} class="group block h-full">
  <div class="bg-white rounded-lg shadow-md hover:shadow-xl transition h-full border-l-4 border-green-600 overflow-hidden flex flex-col">
    <!-- Header -->
    <div class="bg-gradient-to-r from-green-600 to-green-700 px-6 py-8">
      <h3 class="text-2xl font-bold text-white group-hover:text-green-100 transition">
        {name}
      </h3>
    </div>

    <!-- Content -->
    <div class="px-6 py-6 flex-1 flex flex-col">
      <p class="text-gray-600 text-sm leading-relaxed mb-4">
        {description}
      </p>

      <!-- Neighborhoods -->
      {neighborhoods && neighborhoods.length > 0 && (
        <div class="mb-4">
          <p class="text-xs font-bold text-gray-700 mb-2">Service Areas:</p>
          <div class="flex flex-wrap gap-2">
            {neighborhoods.map((neighborhood) => (
              <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">
                {neighborhood}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="flex items-center gap-2 text-green-600 font-bold text-sm group-hover:gap-3 transition mt-auto">
        <span>Get Service</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </div>
  </div>
</a>

<style>
  a {
    text-decoration: none;
  }
</style>
