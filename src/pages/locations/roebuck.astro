---
import Base from '../../layouts/Base.astro';
import { PHONE_NUMBER, SITE_NAME } from '../../utils/constants';
import ContactForm from '../../components/ContactForm.astro';
---

<Base
  title="Tree Service Roebuck, AL | Professional Arborists"
  description="Professional tree removal, trimming, and stump grinding in Roebuck. Licensed, insured, free estimates."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-900 to-green-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tree Service in Roebuck</h1>
        <p class="text-lg text-green-100">
          Professional tree care for Roebuck homes and businesses. Same-day quotes, quality service, fair pricing.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none mb-12">
        <h2>Roebuck's Tree Care Experts</h2>
        <p>
          Roebuck residents trust us for quality tree service at fair prices. We've built our reputation on reliability, expertise, and customer satisfaction throughout the Roebuck community.
        </p>

        <h2>Complete Tree Services for Roebuck</h2>
        <ul>
          <li>Tree removal and stump grinding</li>
          <li>Professional tree trimming and pruning</li>
          <li>Tree health care and disease management</li>
          <li>Emergency storm damage service</li>
          <li>Tree planting and landscaping</li>
          <li>Regular maintenance programs</li>
        </ul>

        <h2>Why Roebuck Trusts Our Team</h2>
        <ul>
          <li>15+ years serving Roebuck and surrounding areas</li>
          <li>Certified, experienced arborists</li>
          <li>Competitive pricing you can trust</li>
          <li>Same-day and next-day service available</li>
          <li>Fully licensed and bonded</li>
          <li>Friendly, professional service</li>
        </ul>

        <h2>Taking Care of Roebuck's Trees</h2>
        <p>
          Whether you need routine maintenance or emergency removal, our team is ready to help. We take pride in serving Roebuck with quality work and honest pricing.
        </p>
      </div>

      <!-- CTA -->
      <div class="bg-green-50 border-2 border-green-200 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Roebuck Tree Service</h3>
        <p class="text-gray-700 mb-6">
          Call today for a free estimate. We're available this week.
        </p>
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="button-primary inline-block"
        >
          Call for Free Quote
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border-2 border-gray-200 p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Get Your Free Estimate</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</Base>
