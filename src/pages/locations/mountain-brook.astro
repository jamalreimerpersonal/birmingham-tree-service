---
import Base from '../../layouts/Base.astro';
import { PHONE_NUMBER, SITE_NAME } from '../../utils/constants';
import ContactForm from '../../components/ContactForm.astro';

const neighborhoods = ['Edgewood', 'Woodland Hills', 'Forest Hills', 'Pinehurst'];
---

<Base
  title="Tree Service Mountain Brook, AL | Professional Arborists"
  description="Professional tree removal, trimming, and stump grinding in Mountain Brook, AL. Licensed, insured, free estimates."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-900 to-green-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tree Service in Mountain Brook</h1>
        <p class="text-lg text-green-100">
          Professional tree care for Mountain Brook's most prestigious properties. Same-day service available.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none mb-12">
        <h2>Tree Service for Mountain Brook's Finest Properties</h2>
        <p>
          Mountain Brook is home to Birmingham's most beautiful estates and manicured landscapes. Maintaining the trees on these prestigious properties requires expertise, precision, and attention to detail. Our certified arborists have been trusted by Mountain Brook homeowners and property managers for years.
        </p>

        <h2>Serving Mountain Brook Neighborhoods</h2>
        <p>
          We provide comprehensive tree care throughout Mountain Brook, including Edgewood, Woodland Hills, Forest Hills, and Pinehurst.
        </p>

        <h2>Why Mountain Brook Residents Choose Us</h2>
        <ul>
          <li>15+ years serving Birmingham's premium neighborhoods</li>
          <li>ISA Certified Arborists</li>
          <li>Licensed, bonded, and fully insured</li>
          <li>Same-day response and weekend availability</li>
          <li>Competitive pricing with premium service</li>
          <li>References from Mountain Brook neighbors</li>
        </ul>

        <h2>Our Mountain Brook Services</h2>
        <ul>
          <li>Tree removal and stump grinding</li>
          <li>Professional tree trimming and pruning</li>
          <li>Tree health assessment and care</li>
          <li>Emergency storm damage removal</li>
          <li>Landscape tree planting and selection</li>
          <li>Property tree management plans</li>
        </ul>

        <h2>The Mountain Brook Difference</h2>
        <p>
          Mountain Brook properties deserve exceptional care. Our team understands the importance of maintaining your landscape's value and beauty. We work with precision and professionalism on every project.
        </p>
      </div>

      <!-- CTA -->
      <div class="bg-green-50 border-2 border-green-200 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Schedule Mountain Brook Tree Service</h3>
        <p class="text-gray-700 mb-6">
          Call for a free consultation. We'll assess your trees and recommend the best care plan.
        </p>
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="button-primary inline-block"
        >
          Call for Free Quote
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border-2 border-gray-200 p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Get Your Free Estimate</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</Base>
