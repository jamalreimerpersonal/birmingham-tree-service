---
import Base from '../../layouts/Base.astro';
import { PHONE_NUMBER, SITE_NAME } from '../../utils/constants';
import ContactForm from '../../components/ContactForm.astro';
---

<Base
  title="Tree Service Downtown Birmingham, AL | Commercial & Residential"
  description="Professional tree service for downtown Birmingham. Residential, commercial, and property management tree care."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-900 to-green-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tree Service in Downtown Birmingham</h1>
        <p class="text-lg text-green-100">
          Professional tree care for downtown Birmingham residents and businesses. Experienced with urban tree management.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none mb-12">
        <h2>Downtown Birmingham Tree Care Specialists</h2>
        <p>
          Downtown living comes with unique tree care challenges. Whether you're a residential loft owner or property manager, our team understands downtown's specific needs and constraints.
        </p>

        <h2>Downtown-Specific Services</h2>
        <ul>
          <li>Urban tree removal with minimal disruption</li>
          <li>Tight-space tree services for downtown lots</li>
          <li>Property management tree programs</li>
          <li>Commercial landscape maintenance</li>
          <li>Quick-turnaround emergency service</li>
          <li>Respectful crews for residential areas</li>
        </ul>

        <h2>Why Downtown Property Owners Choose Us</h2>
        <ul>
          <li>Experience with confined spaces and structures</li>
          <li>Minimal disruption to neighbors</li>
          <li>Clean, professional service</li>
          <li>Flexible scheduling for downtown life</li>
          <li>Competitive commercial rates</li>
          <li>Fully licensed and insured</li>
        </ul>

        <h2>Downtown Urban Forestry</h2>
        <p>
          Downtown trees contribute significantly to Birmingham's character and livability. We're committed to preserving healthy trees while removing hazards. Our team works efficiently to minimize impact on the neighborhood.
        </p>
      </div>

      <!-- CTA -->
      <div class="bg-green-50 border-2 border-green-200 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Downtown Birmingham Tree Service</h3>
        <p class="text-gray-700 mb-6">
          Call for a free estimate. We work with downtown schedules and space constraints.
        </p>
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="button-primary inline-block"
        >
          Call for Free Quote
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border-2 border-gray-200 p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Request Your Free Estimate</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</Base>
