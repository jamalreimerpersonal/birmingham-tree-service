---
import Base from '../../layouts/Base.astro';
import { SITE_NAME, PHONE_NUMBER } from '../../utils/constants';

const pageTitle = 'Tree Service Downtown Birmingham, AL | Commercial & Residential';
const pageDescription = 'Professional tree services for downtown Birmingham including commercial and residential properties. Expert removal and maintenance.';
---

<Base title={pageTitle} description={pageDescription}>
  <section class="bg-gradient-to-r from-green-700 to-green-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Tree Service in Downtown Birmingham</h1>
      <p class="text-xl text-green-100 mb-8">Commercial and residential tree services for downtown Birmingham properties. Expert professionals serving the city center.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={`tel:${PHONE_NUMBER}`} class="bg-white text-green-700 px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">Call {PHONE_NUMBER}</a>
        <a href="/contact" class="border-2 border-white text-white px-8 py-4 rounded-lg font-bold hover:bg-white hover:text-green-700 transition">Get Quote</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">Downtown Birmingham Tree Care</h2>
      <p class="text-gray-600 mb-8">We specialize in both commercial and residential tree services for downtown properties. From small urban apartments to large office buildings, we handle tree removal, trimming, maintenance, and emergency storm damage.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="bg-gray-50 p-8 rounded-lg">
          <h3 class="font-bold text-gray-900 mb-4">Commercial Services:</h3>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li>✓ Office building tree care</li>
            <li>✓ Retail property maintenance</li>
            <li>✓ Emergency storm removal</li>
            <li>✓ Landscape management</li>
          </ul>
        </div>
        <div class="bg-gray-50 p-8 rounded-lg">
          <h3 class="font-bold text-gray-900 mb-4">Residential Services:</h3>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li>✓ Apartment complex trees</li>
            <li>✓ Condo tree removal</li>
            <li>✓ Small space management</li>
            <li>✓ Complete cleanup</li>
          </ul>
        </div>
        <div class="bg-green-50 p-8 rounded-lg">
          <h3 class="font-bold text-gray-900 mb-4">Why Downtown Clients Choose Us:</h3>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li>✓ Licensed & insured</li>
            <li>✓ Professional crews</li>
            <li>✓ Quick response times</li>
            <li>✓ Minimal disruption</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-green-900 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Expert Tree Care for Downtown Properties</h2>
      <a href={`tel:${PHONE_NUMBER}`} class="bg-white text-green-900 px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition inline-block text-lg">
        Call {PHONE_NUMBER}
      </a>
    </div>
  </section>
</Base>
