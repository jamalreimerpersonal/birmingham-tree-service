---
import Base from '../../layouts/Base.astro';
import { SITE_NAME, PHONE_NUMBER } from '../../utils/constants';

const pageTitle = 'Tree Service in Highlands, AL | Premier Tree Care';
const pageDescription = 'Professional tree removal, trimming, and stump grinding for Highlands residents. Premier arboriculture and property care.';
---

<Base title={pageTitle} description={pageDescription}>
  <!-- Hero Image -->
  <section class="bg-white py-0">
    <img src="/images/locations/residential-property-hero.png" alt="Professional tree service at upscale Highlands residential property" class="w-full h-96 object-cover object-center" />
  </section>

  <section class="bg-gradient-to-r from-green-700 to-green-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Premier Tree Service for Highlands</h1>
      <p class="text-xl text-green-100 mb-8">Expert tree care for Highlands residents and property managers. Professional removal, trimming, and maintenance services.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={`tel:${PHONE_NUMBER}`} class="bg-white text-green-700 px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">Call {PHONE_NUMBER}</a>
        <a href="/contact" class="border-2 border-white text-white px-8 py-4 rounded-lg font-bold hover:bg-white hover:text-green-700 transition">Request Quote</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">Highlands Tree Care Excellence</h2>
      <p class="text-gray-600 mb-8">Highlands residents trust us with their most valuable properties. We provide comprehensive tree services including removal, trimming, stump grinding, and emergency storm response—all with the professionalism your community expects.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Complete Tree Services:</h3>
          <ul class="space-y-3 text-gray-600">
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Professional tree removal</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Expert pruning & trimming</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Complete stump grinding</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>24/7 emergency service</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Estate management</span></li>
          </ul>
        </div>
        <div class="bg-gray-50 p-8 rounded-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Why Highlands Choose Us:</h3>
          <ul class="space-y-3 text-gray-600">
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Licensed & insured professionals</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Certified arborists</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Premium service standards</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Transparent pricing</span></li>
            <li class="flex gap-3"><span class="text-green-600">✓</span> <span>Complete cleanup</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-green-900 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Highlands' Premier Tree Service</h2>
      <a href={`tel:${PHONE_NUMBER}`} class="bg-white text-green-900 px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition inline-block text-lg">
        Call {PHONE_NUMBER}
      </a>
    </div>
  </section>
</Base>
