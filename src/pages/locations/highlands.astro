---
import Base from '../../layouts/Base.astro';
import { PHONE_NUMBER, SITE_NAME } from '../../utils/constants';
import ContactForm from '../../components/ContactForm.astro';
---

<Base
  title="Tree Service Highlands, AL | Professional Arborists"
  description="Professional tree removal, trimming, and stump grinding in the Highlands. Licensed, insured, free estimates."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-900 to-green-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tree Service in The Highlands</h1>
        <p class="text-lg text-green-100">
          Premium tree service for The Highlands' beautiful properties. Expert care from certified arborists.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none mb-12">
        <h2>The Highlands Tree Care Specialists</h2>
        <p>
          The Highlands deserves exceptional tree care. Our certified arborists understand the importance of maintaining these prestigious properties with the highest standards of professionalism and expertise.
        </p>

        <h2>Services for The Highlands</h2>
        <ul>
          <li>Precision tree removal on premium properties</li>
          <li>Professional tree trimming and shaping</li>
          <li>Stump grinding and site cleanup</li>
          <li>Emergency storm damage response</li>
          <li>Tree health assessment and care</li>
          <li>Landscape tree consultation</li>
        </ul>

        <h2>Why The Highlands Residents Choose Us</h2>
        <ul>
          <li>ISA certified arborist expertise</li>
          <li>Experience with high-value properties</li>
          <li>Meticulous attention to detail</li>
          <li>Premium service quality</li>
          <li>Fully insured and licensed</li>
          <li>References throughout The Highlands</li>
        </ul>

        <h2>Premium Property Tree Care</h2>
        <p>
          The Highlands properties feature mature, valuable trees that require expert care. We have the knowledge and experience to maintain these trees in perfect condition while ensuring safety and beauty.
        </p>
      </div>

      <!-- CTA -->
      <div class="bg-green-50 border-2 border-green-200 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">The Highlands Tree Service</h3>
        <p class="text-gray-700 mb-6">
          Call for a consultation with our certified arborists. Free estimates available.
        </p>
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="button-primary inline-block"
        >
          Call for Free Quote
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border-2 border-gray-200 p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Request Your Free Estimate</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</Base>
