---
import Base from '../../layouts/Base.astro';
import { SITE_NAME, PHONE_NUMBER } from '../../utils/constants';

const pageTitle = 'Tree Service in Vestavia Hills, AL | Professional Tree Care';
const pageDescription = 'Expert tree removal, trimming, and stump grinding for Vestavia Hills. Serving beautiful estates with professional arboriculture.';
---

<Base title={pageTitle} description={pageDescription}>
  <section class="bg-gradient-to-r from-green-700 to-green-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Professional Tree Service in Vestavia Hills</h1>
      <p class="text-xl text-green-100 mb-8">Expert tree care for Vestavia's beautiful estates and homes. From routine maintenance to emergency removal, we handle all your tree service needs.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={`tel:${PHONE_NUMBER}`} class="bg-white text-green-700 px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">Call {PHONE_NUMBER}</a>
        <a href="/contact" class="border-2 border-white text-white px-8 py-4 rounded-lg font-bold hover:bg-white hover:text-green-700 transition">Get Free Quote</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">Tree Care Excellence for Vestavia Hills</h2>
      <p class="text-gray-600 mb-6">Vestavia Hills residents trust us with their valuable properties. We provide professional tree removal, trimming, stump grinding, and emergency storm damage services that match the quality standards of this prestigious community.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <div class="bg-gray-50 p-8 rounded-lg">
          <h3 class="font-bold text-gray-900 mb-4">Our Services:</h3>
          <ul class="space-y-2 text-gray-600">
            <li>✓ Complete tree removal</li>
            <li>✓ Professional pruning & trimming</li>
            <li>✓ Stump grinding 12-18" below ground</li>
            <li>✓ 24/7 emergency storm removal</li>
            <li>✓ Estate tree management</li>
          </ul>
        </div>
        <div class="bg-green-50 p-8 rounded-lg">
          <h3 class="font-bold text-gray-900 mb-4">Why Vestavia Hills Residents Choose Us:</h3>
          <ul class="space-y-2 text-gray-600">
            <li>✓ Licensed & fully insured</li>
            <li>✓ ISA-certified arborists</li>
            <li>✓ Same-day emergency response</li>
            <li>✓ Transparent pricing</li>
            <li>✓ Complete cleanup services</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-green-900 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Expert Tree Care for Vestavia Hills</h2>
      <a href={`tel:${PHONE_NUMBER}`} class="bg-white text-green-900 px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition inline-block text-lg">
        Call {PHONE_NUMBER} Today
      </a>
    </div>
  </section>
</Base>
