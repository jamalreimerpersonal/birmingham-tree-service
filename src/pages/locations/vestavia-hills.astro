---
import Base from '../../layouts/Base.astro';
import { PHONE_NUMBER, SITE_NAME } from '../../utils/constants';
import ContactForm from '../../components/ContactForm.astro';
---

<Base
  title="Tree Service Vestavia Hills, AL | Professional Arborists"
  description="Tree removal, trimming, and stump grinding in Vestavia Hills, AL. Licensed, insured, free estimates available."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-900 to-green-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tree Service in Vestavia Hills</h1>
        <p class="text-lg text-green-100">
          Expert tree care for Vestavia Hills estates and homes. Comprehensive tree services with immediate availability.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none mb-12">
        <h2>Professional Tree Care in Vestavia Hills</h2>
        <p>
          Vestavia Hills is known for its beautiful tree-lined streets and mature landscapes. Proper tree care is essential for maintaining property value and neighborhood aesthetics. Our team specializes in caring for Vestavia's diverse tree inventory.
        </p>

        <h2>Why Choose Our Vestavia Hills Service?</h2>
        <ul>
          <li>Certified arborists with extensive experience</li>
          <li>Full insurance and bonding for peace of mind</li>
          <li>Same-day and next-day service availability</li>
          <li>Competitive rates for quality work</li>
          <li>References throughout Vestavia Hills</li>
          <li>Respectful, professional crews</li>
        </ul>

        <h2>Complete Tree Services for Vestavia</h2>
        <ul>
          <li>Tree removal and stump grinding</li>
          <li>Professional tree trimming and pruning</li>
          <li>Disease and pest management</li>
          <li>Emergency storm damage removal</li>
          <li>Tree planting and landscape consultation</li>
          <li>Regular maintenance programs</li>
        </ul>

        <h2>Vestavia Hills Tree Care Guide</h2>
        <p>
          The trees in Vestavia Hills face unique challenges from our climate and soil conditions. Regular professional maintenance ensures trees stay healthy, attractive, and safe. We can develop a customized care plan for your property.
        </p>
      </div>

      <!-- CTA -->
      <div class="bg-green-50 border-2 border-green-200 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Get Vestavia Hills Tree Service Today</h3>
        <p class="text-gray-700 mb-6">
          Call now for a free tree assessment and estimate. Available for same-day response.
        </p>
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="button-primary inline-block"
        >
          Call for Free Quote
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border-2 border-gray-200 p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Request Your Free Estimate</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</Base>
