---
import Base from '../../layouts/Base.astro';
import { PHONE_NUMBER, SITE_NAME } from '../../utils/constants';
import { generateServiceSchema } from '../../utils/schema';
import ContactForm from '../../components/ContactForm.astro';

const schema = generateServiceSchema({
  name: 'Professional Tree Removal',
  description: 'Expert tree removal services in Birmingham with stump grinding and debris cleanup.',
  provider: SITE_NAME
});
---

<Base
  title="Professional Tree Removal in Birmingham, AL | Tree Service Birmingham"
  description="Safe, efficient tree removal in Birmingham. Fully licensed, insured, same-day quotes. Serving all neighborhoods."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-900 to-green-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Professional Tree Removal</h1>
        <p class="text-lg text-green-100">
          Safe, efficient tree removal for any size project. From diseased trees to storm damage, we handle it all with expert precision.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none mb-12">
        <h2>Why Choose Professional Tree Removal?</h2>
        <p>
          Tree removal is one of the most dangerous tree care tasks. Attempting to remove trees yourself puts your property and safety at risk. Our certified arborists use state-of-the-art equipment and proven techniques to safely remove trees of any size.
        </p>

        <h2>Our Tree Removal Process</h2>
        <h3>1. Assessment & Planning</h3>
        <p>
          We evaluate the tree's condition, location, and any hazards. Our team creates a detailed removal plan that prioritizes safety and efficiency.
        </p>

        <h3>2. Professional Removal</h3>
        <p>
          Using specialized equipment and techniques, we carefully remove the tree in sections. Our experienced crew maintains complete control throughout the process.
        </p>

        <h3>3. Stump Grinding</h3>
        <p>
          We grind stumps below ground level, eliminating tripping hazards and preventing regrowth. The cleared area is ready for new landscaping.
        </p>

        <h3>4. Debris Cleanup</h3>
        <p>
          All logs, branches, and debris are properly removed from your property. We leave your yard clean and ready to use.
        </p>

        <h2>When to Remove a Tree</h2>
        <ul>
          <li>Dead or dying trees</li>
          <li>Trees damaged by storm or disease</li>
          <li>Trees threatening structures or utilities</li>
          <li>Trees with dangerous root systems</li>
          <li>Trees interfering with new construction</li>
          <li>Overgrown trees creating hazards</li>
        </ul>

        <h2>Why We're Different</h2>
        <ul>
          <li><strong>Licensed & Insured:</strong> Full protection for you and your property</li>
          <li><strong>Certified Arborists:</strong> Expert knowledge and skills</li>
          <li><strong>Modern Equipment:</strong> Latest technology for safe removal</li>
          <li><strong>Same-Day Quotes:</strong> Quick response to urgent needs</li>
          <li><strong>24/7 Emergency Service:</strong> Available when you need us most</li>
          <li><strong>Competitive Pricing:</strong> Best rates in Birmingham</li>
        </ul>

        <h2>Service Areas</h2>
        <p>
          We proudly serve Mountain Brook, Vestavia Hills, Homewood, Downtown Birmingham, Roebuck, Highlands, and all surrounding neighborhoods.
        </p>
      </div>

      <!-- CTA -->
      <div class="bg-green-50 border-2 border-green-200 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Ready to Remove That Tree?</h3>
        <p class="text-gray-700 mb-6">
          Call us anytime for a free, no-obligation estimate. We'll assess your situation and provide transparent pricing.
        </p>
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="button-primary inline-block"
        >
          Call for Free Quote
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border-2 border-gray-200 p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Get a Free Estimate</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</Base>
