---
import Base from '../../layouts/Base.astro';
import { PHONE_NUMBER, SITE_NAME } from '../../utils/constants';
import { generateServiceSchema } from '../../utils/schema';
import ContactForm from '../../components/ContactForm.astro';

const schema = generateServiceSchema({
  name: '24/7 Emergency Tree Removal',
  description: 'Emergency tree removal service 24/7 for storm damage, fallen trees, and hazardous situations.',
  provider: SITE_NAME
});
---

<Base
  title="24/7 Emergency Tree Removal in Birmingham, AL | Tree Service Birmingham"
  description="24/7 emergency tree removal in Birmingham. Storm damage? Fallen tree? We respond immediately, anytime."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-green-900 to-green-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">24/7 Emergency Tree Removal</h1>
        <p class="text-lg text-green-100">
          Storm damage? Fallen tree? We're available anytime to handle emergency situations quickly and safely.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none mb-12">
        <h2>We're Available 24/7 for Emergencies</h2>
        <p>
          Severe weather, ice damage, and falling trees don't wait for business hours. That's why we maintain emergency response crews ready to respond anytime, day or night. Call us immediately if you have a tree emergency.
        </p>

        <h2>Common Tree Emergencies</h2>
        <ul>
          <li>Trees fallen on homes or vehicles</li>
          <li>Branches threatening power lines</li>
          <li>Storm-damaged trees creating hazards</li>
          <li>Trees leaning dangerously toward structures</li>
          <li>Blocked driveways or roads</li>
          <li>Trees damaged by ice or heavy snow</li>
          <li>Limbs hanging over roofs or windows</li>
        </ul>

        <h2>Our Emergency Response Process</h2>
        <h3>Immediate Assessment</h3>
        <p>
          Call us anytime. Our team quickly assesses the hazard and safety risks.
        </p>

        <h3>Priority Stabilization</h3>
        <p>
          We immediately work to stabilize hazards and protect people and property.
        </p>

        <h3>Complete Removal</h3>
        <p>
          Once safe, we remove the damaged tree or debris completely from your property.
        </p>

        <h2>Why You Need Professionals for Emergency Removal</h2>
        <p>
          Emergency tree situations are extremely dangerous. Falling limbs, unstable trunks, and proximity to power lines create serious risks. Professional crews have specialized equipment, training, and experience to handle emergencies safely.
        </p>

        <h2>Safety First</h2>
        <ul>
          <li>Certified, experienced arborists</li>
          <li>Specialized safety equipment</li>
          <li>Power line clearance expertise</li>
          <li>Proper insurance and bonding</li>
          <li>Hazard assessment by professionals</li>
          <li>Property protection measures</li>
        </ul>

        <h2>Storm Preparation Tips</h2>
        <ul>
          <li>Trim dead branches before storm season</li>
          <li>Remove trees leaning toward structures</li>
          <li>Maintain healthy trees through regular care</li>
          <li>Clear gutters of debris</li>
          <li>Keep our emergency number handy</li>
        </ul>
      </div>

      <!-- CTA -->
      <div class="bg-red-50 border-2 border-red-300 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Emergency? Call Immediately</h3>
        <p class="text-gray-700 mb-6">
          Don't wait. Call us right now for emergency tree removal. We respond within the hour, 24/7.
        </p>
        <a 
          href={`tel:${PHONE_NUMBER}`}
          class="button-primary inline-block text-lg"
        >
          {PHONE_NUMBER}
        </a>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border-2 border-gray-200 p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Report Emergency Damage</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</Base>
